GOOGLE_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here  # Alternative name

# Optional: override default model
# GEMINI_MODEL=gemini-2.0-flash

# Optional: comma-separated fallback models for transient errors
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash

# Optional: default temperature (0.0 to 2.0)
# GEMINI_TEMPERATURE=0.2

# Optional: set true only for controlled testing scenarios
# GEMINI_DISABLE_SAFETY_FILTERS=false
